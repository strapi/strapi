JWT_SECRET=replaceme

# OpenTelemetry → local collector (`examples/otel-local`: docker compose up). Disable if no collector.
# Applies to the running app and (when using `strapi develop`) the cluster-primary CLI: compile + admin build → Jaeger service <STRAPI_OTEL_SERVICE_NAME>-cli-primary.
STRAPI_OTEL_ENABLED=true
STRAPI_OTEL_HTTP_ENDPOINT=http://127.0.0.1:4318
STRAPI_OTEL_SERVICE_NAME=strapi-complex
