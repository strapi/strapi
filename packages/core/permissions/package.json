{
  "name": "@strapi/permissions",
  "version": "5.38.0",
  "description": "Strapi's permission layer.",
  "repository": {
    "type": "git",
    "url": "git://github.com/strapi/strapi.git"
  },
  "license": "SEE LICENSE IN LICENSE",
  "author": {
    "name": "Strapi Solutions SAS",
    "email": "hi@strapi.io",
    "url": "https://strapi.io"
  },
  "maintainers": [
    {
      "name": "Strapi Solutions SAS",
      "email": "hi@strapi.io",
      "url": "https://strapi.io"
    }
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "source": "./src/index.ts",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "pnpm exec npm-run-all clean --parallel build:code build:types",
    "build:code": "pnpm exec  rollup -c",
    "build:types": "pnpm exec tsc -p tsconfig.build.json --emitDeclarationOnly",
    "clean": "pnpm exec rimraf ./dist",
    "lint": "pnpm exec eslint .",
    "test:ts": "pnpm exec tsc --noEmit",
    "test:unit": "pnpm exec jest",
    "test:unit:watch": "pnpm exec jest --watch",
    "watch": "pnpm exec rollup -c -w"
  },
  "dependencies": {
    "@casl/ability": "6.7.5",
    "@strapi/utils": "workspace:*",
    "lodash": "4.17.23",
    "qs": "6.15.0",
    "sift": "16.0.1"
  },
  "devDependencies": {
    "eslint-config-custom": "workspace:*",
    "tsconfig": "workspace:*"
  },
  "engines": {
    "node": ">=20.0.0 <=24.x.x",
    "npm": ">=6.0.0"
  }
}
