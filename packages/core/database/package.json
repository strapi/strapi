{
  "name": "@strapi/database",
  "version": "5.38.0",
  "description": "Strapi's database layer",
  "homepage": "https://strapi.io",
  "bugs": {
    "url": "https://github.com/strapi/strapi/issues"
  },
  "repository": {
    "type": "git",
    "url": "git://github.com/strapi/strapi.git"
  },
  "license": "SEE LICENSE IN LICENSE",
  "author": {
    "name": "Strapi Solutions SAS",
    "email": "hi@strapi.io",
    "url": "https://strapi.io"
  },
  "maintainers": [
    {
      "name": "Strapi Solutions SAS",
      "email": "hi@strapi.io",
      "url": "https://strapi.io"
    }
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "source": "./src/index.ts",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "pnpm exec npm-run-all clean --parallel build:code build:types",
    "build:code": "pnpm exec  rollup -c",
    "build:types": "pnpm exec tsc -p tsconfig.build.json --emitDeclarationOnly",
    "clean": "pnpm exec rimraf ./dist",
    "lint": "pnpm exec tsc --noEmit && pnpm exec eslint .",
    "test:unit": "pnpm exec jest",
    "test:unit:watch": "pnpm exec jest --watch",
    "watch": "pnpm exec rollup -c -w"
  },
  "dependencies": {
    "@paralleldrive/cuid2": "2.2.2",
    "@strapi/utils": "workspace:*",
    "ajv": "8.18.0",
    "date-fns": "2.30.0",
    "debug": "4.3.4",
    "fs-extra": "11.2.0",
    "knex": "3.0.1",
    "lodash": "4.17.23",
    "semver": "7.5.4",
    "umzug": "3.8.1"
  },
  "devDependencies": {
    "@types/fs-extra": "11.0.4",
    "eslint-config-custom": "workspace:*",
    "tsconfig": "workspace:*"
  },
  "engines": {
    "node": ">=20.0.0 <=24.x.x",
    "npm": ">=6.0.0"
  }
}
