{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": "../",
    "outDir": "../dist",
    "noEmit": false,
    "types": ["@testing-library/jest-dom", "vite/client", "@strapi/types/globals-admin"]
  },
  "include": ["./src", "../shared", "../ee/admin", "../package.json", "./tests"],
  "exclude": [
