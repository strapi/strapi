{
  "name": "@strapi/generators",
  "version": "5.38.0",
  "description": "Interactive API generator.",
  "keywords": [
    "strapi",
    "generators"
  ],
  "homepage": "https://strapi.io",
  "bugs": {
    "url": "https://github.com/strapi/strapi/issues"
  },
  "repository": {
    "type": "git",
    "url": "git://github.com/strapi/strapi.git"
  },
  "license": "SEE LICENSE IN LICENSE",
  "author": {
    "name": "Strapi Solutions SAS",
    "email": "hi@strapi.io",
    "url": "https://strapi.io"
  },
  "maintainers": [
    {
      "name": "Strapi Solutions SAS",
      "email": "hi@strapi.io",
      "url": "https://strapi.io"
    }
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "source": "./src/index.ts",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "pnpm exec npm-run-all clean --parallel build:code build:types",
    "build:code": "pnpm exec run-p build:code:rollup copy-files",
    "build:code:rollup": "pnpm exec rollup -c",
    "build:types": "pnpm exec tsc -p tsconfig.build.json --emitDeclarationOnly",
    "clean": "pnpm exec rimraf ./dist",
    "copy-files": "copyfiles -u 1 -a 'src/templates/**/*' 'src/files/**/*' dist",
    "lint": "pnpm exec eslint .",
    "test:ts": "pnpm exec tsc --noEmit",
    "test:unit": "pnpm exec jest",
    "test:unit:watch": "pnpm exec jest --watch",
    "watch": "pnpm exec rollup -c -w"
  },
  "dependencies": {
    "@sindresorhus/slugify": "1.1.0",
    "@strapi/typescript-utils": "workspace:*",
    "@strapi/utils": "workspace:*",
    "chalk": "4.1.2",
    "copyfiles": "2.4.1",
    "fs-extra": "11.2.0",
    "handlebars": "4.7.7",
    "jscodeshift": "17.3.0",
    "lodash": "4.17.23",
    "plop": "4.0.1",
    "pluralize": "8.0.0"
  },
  "devDependencies": {
    "@types/fs-extra": "11.0.4",
    "@types/jscodeshift": "0.12.0",
    "eslint-config-custom": "workspace:*",
    "outdent": "^0.8.0",
    "tsconfig": "workspace:*"
  },
  "engines": {
    "node": ">=20.0.0 <=24.x.x",
    "npm": ">=6.0.0"
  }
}
