{
  "name": "@strapi/provider-upload-aws-s3",
  "version": "5.38.0",
  "description": "AWS S3 provider for strapi upload",
  "keywords": [
    "upload",
    "aws",
    "s3",
    "strapi"
  ],
  "homepage": "https://strapi.io",
  "bugs": {
    "url": "https://github.com/strapi/strapi/issues"
  },
  "repository": {
    "type": "git",
    "url": "git://github.com/strapi/strapi.git"
  },
  "license": "SEE LICENSE IN LICENSE",
  "author": {
    "name": "Strapi Solutions SAS",
    "email": "hi@strapi.io",
    "url": "https://strapi.io"
  },
  "maintainers": [
    {
      "name": "Strapi Solutions SAS",
      "email": "hi@strapi.io",
      "url": "https://strapi.io"
    }
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "source": "./src/index.ts",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "pnpm exec npm-run-all clean --parallel build:code build:types",
    "build:code": "pnpm exec  rollup -c",
    "build:types": "pnpm exec tsc -p tsconfig.build.json --emitDeclarationOnly",
    "clean": "pnpm exec rimraf ./dist",
    "lint": "pnpm exec eslint .",
    "test:unit": "pnpm exec jest",
    "test:unit:watch": "pnpm exec jest --watch",
    "watch": "pnpm exec rollup -c -w"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.995.0",
    "@aws-sdk/lib-storage": "3.995.0",
    "@aws-sdk/s3-request-presigner": "3.995.0",
    "@aws-sdk/types": "3.973.1",
    "lodash": "4.17.23"
  },
  "devDependencies": {
    "@types/jest": "29.5.2",
    "eslint-config-custom": "workspace:*",
    "tsconfig": "workspace:*"
  },
  "engines": {
    "node": ">=20.0.0 <=24.x.x",
    "npm": ">=6.0.0"
  }
}
