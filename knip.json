{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "ignoreWorkspaces": [
    "examples/**",
    "docs/**",
    "tests/**",
    ".github/**",
    "scripts/**",
    "packages/utils/api-tests"
  ],
  "ignoreBinaries": ["run"],
  "ignoreUnresolved": ["eslint-config-custom/.+"],
  "ignoreDependencies": ["@strapi/provider-email-.*", "@strapi/provider-upload-.*"],
  "workspaces": {
    "packages/core/*": {
      "entry": [
        "admin/src/index.{js,jsx,ts,tsx}!",
        "server/src/index.{js,ts}!",
        "shared/index.{js,ts}!",
        "src/index.ts!",
        "src/admin.ts!",
        "src/admin-test.ts!",
        "bin/*.js!"
      ],
      "project": [
        "admin/**/*.{js,jsx,ts,tsx}!",
        "server/**/*.{js,ts}!",
        "shared/**/*.{js,ts}!",
        "src/**/*.{js,ts}!"
      ]
    },
    "packages/core/strapi": {
      "entry": [
        "src/index.ts!",
        "src/admin.ts!",
        "src/admin-test.ts!",
        "bin/strapi.js!",
        "src/cli/index.ts!"
      ],
      "project": ["src/**/*.{js,ts}!"]
    },
    "packages/plugins/*": {
      "entry": [
        "admin/src/index.{js,jsx,ts,tsx}!",
        "server/src/index.{js,ts}!",
        "strapi-admin.js!",
        "strapi-server.js!"
      ],
      "project": [
        "admin/**/*.{js,jsx,ts,tsx}!",
        "server/**/*.{js,ts}!",
        "strapi-admin.js!",
        "strapi-server.js!"
      ]
    },
    "packages/cli/*": {
      "entry": ["src/index.{js,ts}!", "bin/*.js!"],
      "project": ["src/**/*.{js,ts}!"]
    },
    "packages/providers/*": {
      "entry": ["src/index.{js,ts}!"],
      "project": ["src/**/*.{js,ts}!"]
    },
    "packages/utils/*": {
      "entry": ["src/index.{js,ts}!", "lib/index.js!"],
      "project": ["src/**/*.{js,ts}!", "lib/**/*.js!"]
    },
    "packages/generators/*": {
      "entry": ["src/index.{js,ts}!"],
      "project": ["src/**/*.{js,ts}!"]
    },
    "packages/admin-test-utils": {
      "entry": ["src/index.{js,ts}!"],
      "project": ["src/**/*.{js,jsx,ts,tsx}!"]
    }
  }
}
