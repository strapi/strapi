# Optional defaults for `yarn test:migrations:v5` (copy to `.env` in this directory)
# CLI flags override these values.

# postgres | mysql | sqlite
# DATABASE_CLIENT=postgres

# Host ports for Docker publish (defaults: script picks a free port, preferring 5432 / 3306).
# Leave unset to auto-detect; set both POSTGRES_PORT and DATABASE_PORT to the same value to pin.
# POSTGRES_PORT=5433
# DATABASE_PORT=5433
# MYSQL_PORT=3307

# Compose project name for Postgres/MySQL containers (isolated from other dev work)
# STRAPI_MIGRATION_COMPOSE_PROJECT=strapi_migration_v5

# Seed scale (also SEED_MULTIPLIER / MIGRATION_MULTIPLIER)
# MIGRATION_MULTIPLIER=1
