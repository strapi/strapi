# =============================================================================
# Community PR Triage — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# For GitHub Actions, add each as a repository secret.
# =============================================================================

# --- Linear API ---

# Linear personal API key (Settings → API → Personal API keys)
LINEAR_API_KEY=

# --- Linear IDs ---

# Team ID for CMS-Community-PRs (where triage issues are created)
LINEAR_CPR_TEAM_ID=

# Team ID for CMS (main team, day-to-day work)
LINEAR_CMS_TEAM_ID=

# Team ID for CMS-GitHub (where GitHub issues live)
LINEAR_CMS_GITHUB_TEAM_ID=

# Project ID for tracking and milestone creation
LINEAR_PROJECT_ID=

# --- Linear Workflow Status IDs ---
# Find these in Linear: Settings → Teams → <team> → Workflow → click each status

# Status ID for "Todo" (accepted into backlog)
LINEAR_STATUS_TODO=

# Status ID for "Done" (PR merged / issue resolved)
LINEAR_STATUS_DONE=

# Status ID for "Canceled" (PR closed without merge)
LINEAR_STATUS_CANCELED=

# --- Linear Labels (JSON) ---

# Area labels — maps area names to Linear label IDs
# Example: {"bug":"<label-id>","feature":"<label-id>","improvement":"<label-id>"}
LINEAR_LABELS={}

# Triage-specific labels — structured JSON with sub-categories
# Example:
# {
#   "priority": {"urgent":"<id>","high":"<id>","normal":"<id>","low":"<id>"},
#   "complexity": {"low":"<id>","medium":"<id>","high":"<id>","very_high":"<id>"},
#   "quickWin": "<id>",
#   "hasLinkedIssue": "<id>",
#   "ci": {"passing":"<id>","failing":"<id>","pending":"<id>"}
# }
LINEAR_TRIAGE_LABELS={}


# --- Optional: AI-powered relation detection ---

# Anthropic API key (only needed if using ai-relations feature)
# ANTHROPIC_API_KEY=
