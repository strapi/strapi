{
  "compilerOptions": {
    "rootDir": ".",
    "noEmit": true,
    "module": "commonjs",
    "target": "es6"
  },
  "exclude": [
    "**/node_modules/*",
    ".git",
    ".npm",
    ".nx",
    "**/.cache/*",
    "**/.tmp/*",
    "**/.docusaurus/*",
    "**/dist/*",
    "**/build/*",
    "**/coverage/*",
    "**/*.test.js",
    "**/*.test.api.js",

    ".github/actions",
    "packages",
    "examples",
    "templates"
  ]
}
