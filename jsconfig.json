{
  "compilerOptions": {
    "rootDir": ".",
    "module": "commonjs",
    "target": "es6"
  },
  "exclude": [
    "**/node_modules/*",
    ".git",
    ".npm",
    ".nx",
    "**/.cache/*",
    "**/.tmp/*",
    "**/dist/*",
    "**/build/*",
    "**/*.test.js",
    "**/*.test.api.js",
    "docs",
    "examples",
    "templates",
    ".github",
    "packages",
    "scripts",
    "tests"
  ]
}
