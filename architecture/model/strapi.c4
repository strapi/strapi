  public_client -> strapi 'Consumes published content through Content APIs' 'HTTP'
  external_system -> strapi 'Integrates with Strapi through APIs, providers, deployment workflows, or webhooks' 'HTTP / provider APIs'
  content_editor -> strapi 'Creates, edits, reviews, and publishes entries' 'Admin UI'
  developer -> strapi 'Builds schemas, APIs, extensions, and deployment configuration' 'Code, CLI, and Admin UI'
  administrator -> strapi 'Configures users, roles, permissions, tokens, webhooks, and operational settings' 'Admin UI'
}
